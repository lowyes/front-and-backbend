page {
  background-color: #F8FAFC;
  min-height: 100vh;
}

.page-container {
  min-height: 100vh;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 32rpx;
  background: #FFFFFF;
  position: sticky;
  top: 0;
  z-index: 100;
}

.header-left, .header-right {
  width: 80rpx;
}

.back-icon {
  font-size: 40rpx;
  color: #0F172A;
}

.header-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #0F172A;
}

.content {
  padding: 32rpx;
}

.result-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx;
  border-radius: 24rpx;
  margin-bottom: 32rpx;
}

.result-card.success {
  background: linear-gradient(135deg, #DCFCE7 0%, #BBF7D0 100%);
}

.result-card.uncertain {
  background: linear-gradient(135deg, #FEFCE8 0%, #FEF9C3 100%);
}

.result-card.failed {
  background: linear-gradient(135deg, #FEE2E2 0%, #FECACA 100%);
}

.result-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  font-size: 40rpx;
  font-weight: 700;
}

.success-icon {
  background: #16A34A;
  color: #FFFFFF;
}

.uncertain-icon {
  background: #F97316;
  color: #FFFFFF;
}

.failed-icon {
  background: #DC2626;
  color: #FFFFFF;
}

.result-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #0F172A;
  margin-bottom: 8rpx;
}

.result-subtitle {
  font-size: 26rpx;
  color: #64748B;
}

.detail-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.detail-header {
  margin-bottom: 24rpx;
}

.detail-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #0F172A;
}

.model-info {
  margin-bottom: 32rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 72rpx;
  border-bottom: 1rpx solid #F1F5F9;
}

.info-label {
  font-size: 28rpx;
  color: #64748B;
}

.info-value {
  font-size: 28rpx;
  color: #0F172A;
}

.info-value.mono {
  font-family: monospace;
  font-size: 26rpx;
}

.info-value.success {
  color: #16A34A;
}

.score-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F1F5F9;
}

.score-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.score-label {
  font-size: 24rpx;
  color: #94A3B8;
}

.score-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #2563EB;
}

.action-row {
  display: flex;
  gap: 24rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  height: 88rpx;
  border-radius: 16rpx;
}

.action-btn.primary {
  background: linear-gradient(135deg, #2563EB 0%, #1D4ED8 100%);
  color: #FFFFFF;
}

.action-btn.secondary {
  background: #F1F5F9;
  color: #0F172A;
}

.btn-icon {
  font-size: 28rpx;
}

.btn-text {
  font-size: 28rpx;
  font-weight: 500;
}

.candidates-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.candidates-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.candidates-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #0F172A;
}

.candidates-count {
  font-size: 24rpx;
  color: #94A3B8;
}

.candidate-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.candidate-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #F8FAFC;
  border-radius: 16rpx;
}

.candidate-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.candidate-name {
  font-size: 30rpx;
  color: #0F172A;
}

.candidate-id {
  font-size: 24rpx;
  font-family: monospace;
  color: #94A3B8;
}

.candidate-score {
  margin-right: 24rpx;
}

.candidate-arrow {
  font-size: 28rpx;
  color: #94A3B8;
}

.candidate-tip {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 24rpx;
  padding: 20rpx;
  background: #FEFCE8;
  border-radius: 12rpx;
}

.tip-icon {
  font-size: 24rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #854D0E;
}

.no-match-actions {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.debug-section {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-top: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.debug-header {
  margin-bottom: 24rpx;
}

.debug-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #0F172A;
}

.debug-content {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.debug-label {
  font-size: 24rpx;
  color: #94A3B8;
  font-weight: 500;
}

.debug-code {
  background: #0F172A;
  color: #10B981;
  padding: 20rpx;
  border-radius: 12rpx;
  font-family: monospace;
  font-size: 22rpx;
  white-space: pre-wrap;
  word-break: break-all;
  max-height: 400rpx;
  overflow-y: auto;
}