<view class="page-container">
  <view class="header">
    <view class="header-left" bindtap="goBack">
      <text class="back-icon">←</text>
    </view>
    <text class="header-title">识别结果</text>
    <view class="header-right"></view>
  </view>

  <view class="content" wx:if="{{result}}">
    <view class="result-card success" wx:if="{{result.matched && result.top1}}">
      <view class="result-icon success-icon">✓</view>
      <text class="result-title">识别成功</text>
      <text class="result-subtitle">找到匹配的三维模型</text>
    </view>

    <view class="result-card uncertain" wx:elif="{{!result.matched && result.candidates && result.candidates.length > 0}}">
      <view class="result-icon uncertain-icon">?</view>
      <text class="result-title">识别不确定</text>
      <text class="result-subtitle">以下候选模型可供参考</text>
    </view>

    <view class="result-card failed" wx:else>
      <view class="result-icon failed-icon">✗</view>
      <text class="result-title">未匹配到模型</text>
      <text class="result-subtitle">{{result.message || '请尝试上传更清晰的工程图'}}</text>
    </view>

    <view class="detail-card" wx:if="{{result.matched && result.top1}}">
      <view class="detail-header">
        <text class="detail-title">匹配模型</text>
      </view>
      <view class="model-info">
        <view class="info-row">
          <text class="info-label">模型名称</text>
          <text class="info-value">{{result.top1.name}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">模型ID</text>
          <text class="info-value mono">{{result.top1.model_id}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">匹配度</text>
          <text class="info-value">{{formatScore(result.top1.final_score)}}</text>
        </view>
        <view class="score-row">
          <view class="score-item">
            <text class="score-label">VLM评分</text>
            <text class="score-value">{{formatScore(result.top1.vlm_score)}}</text>
          </view>
          <view class="score-item">
            <text class="score-label">配对评分</text>
            <text class="score-value">{{formatScore(result.top1.pair_judge_score)}}</text>
          </view>
        </view>
        <view class="info-row">
          <text class="info-label">判定结果</text>
          <text class="info-value success">{{result.top1.decision}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">匹配原因</text>
          <text class="info-value">{{result.top1.reason}}</text>
        </view>
      </view>
      <view class="action-row">
        <view class="action-btn primary" bindtap="goToModelViewer">
          <text class="btn-icon">H5</text>
          <text class="btn-text">查看3D模型</text>
        </view>
        <view class="action-btn secondary" bindtap="toggleDebug">
          <text class="btn-icon">🔧</text>
          <text class="btn-text">展开调试信息</text>
        </view>
      </view>
    </view>

    <view class="candidates-card" wx:if="{{!result.matched && result.candidates && result.candidates.length > 0}}">
      <view class="candidates-header">
        <text class="candidates-title">候选模型</text>
        <text class="candidates-count">共 {{result.candidates.length}} 个</text>
      </view>
      <view class="candidate-list">
        <view 
          class="candidate-item" 
          wx:for="{{result.candidates}}" 
          wx:key="model_id"
          bindtap="selectCandidate"
          data-candidate="{{item}}"
        >
          <view class="candidate-info">
            <text class="candidate-name">{{item.name}}</text>
            <text class="candidate-id mono">{{item.model_id}}</text>
          </view>
          <view class="candidate-score">
            <text class="score-value">{{formatScore(item.final_score)}}</text>
          </view>
          <text class="candidate-arrow">→</text>
        </view>
      </view>
      <view class="candidate-tip">
        <text class="tip-icon">⚠️</text>
        <text class="tip-text">候选模型仅供参考，请确认是否匹配</text>
      </view>
    </view>

    <view class="no-match-actions" wx:if="{{!result.matched && (!result.candidates || result.candidates.length === 0)}}">
      <view class="action-btn primary" bindtap="goBack">
        <text class="btn-icon">🔄</text>
        <text class="btn-text">重新上传</text>
      </view>
      <view class="action-btn secondary" bindtap="goToModelList">
        <text class="btn-icon">📦</text>
        <text class="btn-text">查看模型库</text>
      </view>
    </view>

    <view class="debug-section" wx:if="{{showDebug}}">
      <view class="debug-header">
        <text class="debug-title">调试信息</text>
      </view>
      <view class="debug-content">
        <text class="debug-label">top1</text>
        <view class="debug-code">
          <text>{{JSON.stringify(result.top1, null, 2)}}</text>
        </view>
        <text class="debug-label">candidates</text>
        <view class="debug-code">
          <text>{{JSON.stringify(result.candidates, null, 2)}}</text>
        </view>
        <text class="debug-label">query_signature</text>
        <view class="debug-code">
          <text>{{JSON.stringify(result.query_signature, null, 2)}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
