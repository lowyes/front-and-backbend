page {
  width: 100%;
  height: 100%;
  background: #101827;
}

.page {
  width: 100%;
  min-height: 100vh;
  background: #101827;
  color: #E5EEFC;
}

.header {
  height: 88rpx;
  padding: 0 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #FFFFFF;
  color: #0F172A;
}

.back,
.header-space {
  width: 72rpx;
}

.back {
  font-size: 44rpx;
}

.title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.viewer {
  position: relative;
  width: 100%;
  height: calc(100vh - 208rpx);
  background: #101827;
}

.native-canvas {
  width: 100%;
  height: 100%;
  display: block;
}

.status-panel {
  position: absolute;
  left: 32rpx;
  right: 32rpx;
  bottom: 36rpx;
  min-height: 88rpx;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  background: rgba(15, 23, 42, 0.86);
}

.spinner {
  width: 36rpx;
  height: 36rpx;
  border: 4rpx solid #2F8CFF;
  border-top-color: #FFFFFF;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  flex: 0 0 auto;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.status-text,
.error-text {
  font-size: 26rpx;
  line-height: 1.45;
}

.error-text {
  color: #FCA5A5;
}

.model-label {
  position: absolute;
  left: 32rpx;
  top: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.35);
}

.model-id {
  font-size: 24rpx;
  color: #B6C7DF;
  font-family: monospace;
}

.toolbar {
  height: 120rpx;
  padding: 16rpx 28rpx;
  box-sizing: border-box;
  display: flex;
  gap: 20rpx;
  background: #FFFFFF;
}

.tool-btn {
  flex: 1;
  height: 76rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #2563EB;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
}
