<view class="page">
  <view class="header">
    <view class="back" bindtap="goBack">←</view>
    <view class="title">{{model.name || '3D模型查看'}}</view>
    <view class="header-space"></view>
  </view>

  <view class="viewer">
    <canvas
      id="nativeGl"
      class="native-canvas"
      type="webgl"
      bindtouchstart="onTX"
      bindtouchmove="onTX"
      bindtouchend="onTX"
      bindtouchcancel="onTX"
    ></canvas>

    <view class="status-panel" wx:if="{{loading || hasError}}">
      <view class="spinner" wx:if="{{loading}}"></view>
      <text class="status-text">{{statusText}}</text>
      <text class="error-text" wx:if="{{hasError}}">{{errorMessage}}</text>
    </view>

    <view class="model-label">
      <text>{{model.name || '-'}}</text>
      <text class="model-id">{{model.model_id || '-'}}</text>
    </view>
  </view>

  <view class="toolbar">
    <view class="tool-btn" bindtap="resetView">重置视角</view>
  </view>
</view>
