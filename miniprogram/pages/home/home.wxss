page {
  background-color: #F8FAFC;
  min-height: 100vh;
}

.page-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

.header {
  background: linear-gradient(135deg, #2563EB 0%, #1D4ED8 100%);
  padding: 80rpx 40rpx 100rpx;
  border-radius: 0 0 48rpx 48rpx;
}

.header-content {
  text-align: center;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 20rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
}

.content {
  flex: 1;
  padding: 40rpx;
  padding-top: 60rpx;
}

.example-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.example-header {
  margin-bottom: 24rpx;
}

.example-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #0F172A;
}

.example-image {
  width: 100%;
  height: 320rpx;
  background: #F1F5F9;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.image-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.placeholder-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.placeholder-text {
  font-size: 26rpx;
  color: #64748B;
}

.example-info {
  display: flex;
  gap: 32rpx;
}

.info-text {
  font-size: 24rpx;
  color: #94A3B8;
}

.button-group {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  height: 100rpx;
  border-radius: 20rpx;
  font-size: 32rpx;
  font-weight: 600;
  transition: all 0.3s;
}

.action-btn.primary {
  background: linear-gradient(135deg, #2563EB 0%, #1D4ED8 100%);
  color: #FFFFFF;
}

.action-btn.secondary {
  background: #FFFFFF;
  color: #2563EB;
  border: 2rpx solid #2563EB;
}

.action-btn[disabled] {
  opacity: 0.6;
}

.btn-icon {
  font-size: 36rpx;
}

.btn-text {
  font-size: 32rpx;
}

.quick-links {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 8rpx 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.link-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 96rpx;
  border-bottom: 1rpx solid #E2E8F0;
}

.link-item:last-child {
  border-bottom: none;
}

.link-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.link-text {
  flex: 1;
  font-size: 30rpx;
  color: #0F172A;
}

.link-arrow {
  font-size: 28rpx;
  color: #94A3B8;
}

.tip-box {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 32rpx;
  background: #FEFCE8;
  border-radius: 16rpx;
  border: 1rpx solid #FEF08A;
}

.tip-icon {
  font-size: 28rpx;
}

.tip-text {
  font-size: 26rpx;
  color: #854D0E;
}