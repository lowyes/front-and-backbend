<view class="page-container">
  <view class="header">
    <view class="header-content">
      <text class="title">工程制图辅助学习</text>
      <text class="subtitle">上传二维工程图，匹配对应三维模型</text>
    </view>
  </view>

  <view class="content">
    <view class="example-card">
      <view class="example-header">
        <text class="example-title">📐 示例工程图</text>
      </view>
      <view class="example-image">
        <view class="image-placeholder">
          <text class="placeholder-icon">📝</text>
          <text class="placeholder-text">轴承座类零件三视图</text>
        </view>
      </view>
      <view class="example-info">
        <text class="info-text">支持 JPG、PNG、BMP 格式</text>
        <text class="info-text">建议尺寸：600×800 像素以上</text>
      </view>
    </view>

    <view class="button-group">
      <view 
        class="action-btn primary" 
        bindtap="takePhoto"
        disabled="{{isLoading}}"
      >
        <text class="btn-icon">📷</text>
        <text class="btn-text">拍照识别</text>
      </view>

      <view 
        class="action-btn secondary" 
        bindtap="chooseFromAlbum"
        disabled="{{isLoading}}"
      >
        <text class="btn-icon">📁</text>
        <text class="btn-text">从相册选择</text>
      </view>
    </view>

    <view class="quick-links">
      <view class="link-item" bindtap="goToModelList">
        <text class="link-icon">📦</text>
        <text class="link-text">查看模型库</text>
        <text class="link-arrow">→</text>
      </view>
      <view class="link-item" bindtap="goToDebug">
        <text class="link-icon">🔧</text>
        <text class="link-text">调试信息</text>
        <text class="link-arrow">→</text>
      </view>
    </view>

    <view class="tip-box">
      <text class="tip-icon">💡</text>
      <text class="tip-text">识别前请确保工程图清晰，避免阴影和反光</text>
    </view>
  </view>
</view>