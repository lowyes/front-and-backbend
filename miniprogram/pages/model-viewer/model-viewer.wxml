<view class="page-container">
  <view class="header">
    <view class="header-left" bindtap="goBack">
      <text class="back-icon">←</text>
    </view>
    <text class="header-title">3D模型查看</text>
    <view class="header-right"></view>
  </view>

  <view class="content" wx:if="{{!hasError && model}}">
    <view class="model-info-card">
      <view class="info-row">
        <text class="info-label">模型名称</text>
        <text class="info-value">{{model.name}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">模型ID</text>
        <text class="info-value mono">{{model.model_id}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">GLTF路径</text>
        <text class="info-value mono small">{{model.gltf_url || '-'}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">BIN文件</text>
        <text class="info-value mono small">{{model.bin_file || '-'}}</text>
      </view>
    </view>

    <view class="model-preview">
      <xr-scene
        id="xrScene"
        class="xr-scene"
        style="width: 100%; height: 500rpx; display: block; border-radius: 16rpx; overflow: hidden; background: #0f172a;"
        bind:ready="handleSceneReady"
      >
        <xr-assets
          bind:progress="handleAssetsProgress"
          bind:loaded="handleAssetsLoaded"
          bind:error="handleAssetsError"
        >
          <xr-asset-load
            type="gltf"
            asset-id="current-part-model"
            src="{{model.gltf_url}}"
            options="ignoreError: -1"
          />
        </xr-assets>

        <xr-light type="ambient" color="1 1 1" intensity="1.2" />
        <xr-light type="directional" rotation="45 30 0" color="1 1 1" intensity="2" />

        <xr-node>
          <xr-gltf
            node-id="partModel"
            model="current-part-model"
            position="0 0 0"
            rotation="{{modelRotation}}"
            scale="{{modelScale}} {{modelScale}} {{modelScale}}"
            bind:gltf-loaded="handleGltfLoaded"
            bind:gltf-error="handleGltfError"
          />
        </xr-node>

        <xr-camera
          id="camera"
          node-id="camera"
          position="0 0 4"
          target="0 0 0"
          near="0.01"
          far="1000"
          clear-color="0.06 0.09 0.15 1"
        />
      </xr-scene>

      <view class="loading-overlay" wx:if="{{isLoading}}">
        <view class="loading-spinner"></view>
        <text class="loading-text">{{loadingText}}</text>
      </view>
    </view>

    <view class="model-actions">
      <view class="action-card" bindtap="zoomOut">
        <text class="action-icon">−</text>
        <text class="action-text">缩小</text>
      </view>
      <view class="action-card" bindtap="resetView">
        <text class="action-icon">⟲</text>
        <text class="action-text">重置视角</text>
      </view>
      <view class="action-card" bindtap="zoomIn">
        <text class="action-icon">+</text>
        <text class="action-text">放大</text>
      </view>
    </view>

    <view class="bottom-actions">
      <view class="nav-btn secondary" bindtap="goBack">
        <text class="nav-btn-text">返回上一页</text>
      </view>
    </view>
  </view>

  <view class="error-content" wx:elif="{{hasError}}">
    <view class="error-card">
      <view class="error-icon">×</view>
      <text class="error-title">加载失败</text>
      <text class="error-message">{{errorMessage}}</text>
      <view class="action-btn" bindtap="goBack">
        <text class="btn-text">返回</text>
      </view>
    </view>
  </view>
</view>
