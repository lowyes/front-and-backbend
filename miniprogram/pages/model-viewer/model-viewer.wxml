<view class="page-container">
  <view class="header">
    <view class="header-left" bindtap="goBack">
      <text class="back-icon">←</text>
    </view>
    <text class="header-title">3D模型查看</text>
    <view class="header-right"></view>
  </view>

  <view class="content" wx:if="{{!hasError && model}}">
    <view class="model-info-card">
      <view class="info-row">
        <text class="info-label">模型名称</text>
        <text class="info-value">{{model.name}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">模型ID</text>
        <text class="info-value mono">{{model.model_id}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">GLTF路径</text>
        <text class="info-value mono small">{{model.gltf_url || '-'}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">BIN文件</text>
        <text class="info-value mono small">{{model.bin_file || '-'}}</text>
      </view>
    </view>

    <view class="model-preview">
      <canvas 
        type="webgl" 
        id="modelCanvas" 
        class="model-canvas"
        bindtouchstart="onTouchStart"
        bindtouchmove="onTouchMove"
        bindtouchend="onTouchEnd"
      ></canvas>
      
      <view class="loading-overlay" wx:if="{{isLoading}}">
        <view class="loading-spinner"></view>
        <text class="loading-text">加载中...</text>
      </view>
    </view>

    <view class="model-actions">
      <view class="action-card" bindtap="zoomOut">
        <text class="action-icon">−</text>
        <text class="action-text">缩小</text>
      </view>
      <view class="action-card" bindtap="resetView">
        <text class="action-icon">⟲</text>
        <text class="action-text">重置视角</text>
      </view>
      <view class="action-card" bindtap="zoomIn">
        <text class="action-icon">+</text>
        <text class="action-text">放大</text>
      </view>
    </view>

    <view class="bottom-actions">
      <view class="nav-btn secondary" bindtap="goBack">
        <text class="nav-btn-text">返回上一页</text>
      </view>
    </view>
  </view>

  <view class="error-content" wx:elif="{{hasError}}">
    <view class="error-card">
      <view class="error-icon">×</view>
      <text class="error-title">加载失败</text>
      <text class="error-message">{{errorMessage}}</text>
      <view class="action-btn" bindtap="goBack">
        <text class="btn-text">返回</text>
      </view>
      <view class="nav-btn secondary error-back-btn" bindtap="goBack">
        <text class="nav-btn-text">返回上一页</text>
      </view>
    </view>
  </view>
</view>