page {
  background-color: #F8FAFC;
  min-height: 100vh;
}

.page-container {
  min-height: 100vh;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 32rpx;
  background: #FFFFFF;
  position: sticky;
  top: 0;
  z-index: 100;
}

.header-left, .header-right {
  width: 80rpx;
}

.back-icon {
  font-size: 40rpx;
  color: #0F172A;
}

.header-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #0F172A;
}

.content {
  padding: 32rpx;
}

.model-info-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 72rpx;
  border-bottom: 1rpx solid #F1F5F9;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #64748B;
}

.info-value {
  font-size: 28rpx;
  color: #0F172A;
}

.info-value.mono {
  font-family: monospace;
}

.info-value.small {
  font-size: 24rpx;
  color: #94A3B8;
}

.model-preview {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.preview-placeholder {
  width: 100%;
  height: 500rpx;
  background: linear-gradient(135deg, #1E293B 0%, #0F172A 100%);
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.placeholder-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.placeholder-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 12rpx;
}

.placeholder-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 8rpx;
}

.placeholder-hint {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

.model-actions {
  display: flex;
  gap: 24rpx;
}

.action-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 16rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.action-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.action-text {
  font-size: 26rpx;
  color: #64748B;
}

.error-content {
  padding: 32rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 60vh;
}

.error-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.error-icon {
  font-size: 64rpx;
  margin-bottom: 20rpx;
}

.error-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #0F172A;
  margin-bottom: 12rpx;
}

.error-message {
  font-size: 28rpx;
  color: #64748B;
  margin-bottom: 32rpx;
}

.action-btn {
  padding: 24rpx 64rpx;
  background: linear-gradient(135deg, #2563EB 0%, #1D4ED8 100%);
  border-radius: 16rpx;
}

.btn-text {
  font-size: 30rpx;
  font-weight: 500;
  color: #FFFFFF;
}