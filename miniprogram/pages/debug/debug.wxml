<view class="page-container">
  <view class="header">
    <view class="header-left" bindtap="goBack">
      <text class="back-icon">←</text>
    </view>
    <text class="header-title">调试信息</text>
    <view class="header-right"></view>
  </view>

  <view class="content">
    <view class="section">
      <view class="section-header">
        <text class="section-title">最近识别结果</text>
      </view>
      <view class="section-content">
        <view class="json-code">
          <text>{{resultJson}}</text>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-header">
        <text class="section-title">当前模型</text>
      </view>
      <view class="section-content">
        <view class="json-code">
          <text>{{currentModelJson}}</text>
        </view>
      </view>
    </view>

    <view class="action-section">
      <view class="action-btn" bindtap="clearStorage">
        <text class="btn-icon">🗑️</text>
        <text class="btn-text">清除缓存</text>
      </view>
    </view>
  </view>
</view>