page {
  background-color: #F8FAFC;
  min-height: 100vh;
}

.page-container {
  min-height: 100vh;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 32rpx;
  background: #FFFFFF;
  position: sticky;
  top: 0;
  z-index: 100;
}

.header-left, .header-right {
  width: 80rpx;
}

.back-icon {
  font-size: 40rpx;
  color: #0F172A;
}

.header-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #0F172A;
}

.content {
  padding: 32rpx;
}

.section {
  background: #FFFFFF;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #F1F5F9;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #0F172A;
}

.section-content {
  padding: 24rpx 32rpx;
}

.json-code {
  background: #0F172A;
  color: #10B981;
  padding: 24rpx;
  border-radius: 12rpx;
  font-family: monospace;
  font-size: 22rpx;
  white-space: pre-wrap;
  word-break: break-all;
  max-height: 500rpx;
  overflow-y: auto;
}

.action-section {
  padding-top: 16rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  height: 88rpx;
  background: #EF4444;
  border-radius: 16rpx;
}

.btn-icon {
  font-size: 28rpx;
}

.btn-text {
  font-size: 30rpx;
  font-weight: 500;
  color: #FFFFFF;
}