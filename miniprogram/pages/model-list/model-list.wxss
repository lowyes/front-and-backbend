page {
  background-color: #F8FAFC;
  min-height: 100vh;
}

.page-container {
  min-height: 100vh;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 32rpx;
  background: #FFFFFF;
  position: sticky;
  top: 0;
  z-index: 100;
}

.header-left, .header-right {
  width: 80rpx;
}

.back-icon {
  font-size: 40rpx;
  color: #0F172A;
}

.header-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #0F172A;
}

.content {
  padding: 32rpx;
}

.info-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.info-text {
  font-size: 28rpx;
  color: #64748B;
}

.data-source {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  background: #FEFCE8;
  border-radius: 8rpx;
}

.source-icon {
  font-size: 22rpx;
}

.source-text {
  font-size: 22rpx;
  color: #854D0E;
}

.model-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.model-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.model-image {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  overflow: hidden;
  margin-right: 24rpx;
}

.image-placeholder {
  width: 100%;
  height: 100%;
  background: #F1F5F9;
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-icon {
  font-size: 40rpx;
}

.model-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.model-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #0F172A;
}

.model-id {
  font-size: 24rpx;
  font-family: monospace;
  color: #94A3B8;
}

.model-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.meta-item {
  font-size: 24rpx;
  color: #64748B;
  padding: 4rpx 12rpx;
  background: #F1F5F9;
  border-radius: 8rpx;
}

.has-gltf {
  padding: 4rpx 12rpx;
  background: linear-gradient(135deg, #2563EB 0%, #1D4ED8 100%);
  border-radius: 8rpx;
}

.gltf-icon {
  font-size: 22rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.model-arrow {
  font-size: 28rpx;
  color: #94A3B8;
  margin-left: 16rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 32rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #0F172A;
  margin-bottom: 12rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #64748B;
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 32rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #F1F5F9;
  border-top-color: #2563EB;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 28rpx;
  color: #64748B;
}