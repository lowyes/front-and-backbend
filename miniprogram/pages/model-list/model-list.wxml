<view class="page-container">
  <view class="header">
    <view class="header-left" bindtap="goBack">
      <text class="back-icon">←</text>
    </view>
    <text class="header-title">模型库</text>
    <view class="header-right"></view>
  </view>

  <view class="content">
    <view class="info-bar">
      <text class="info-text">共 {{models.length}} 个模型</text>
      <view class="data-source" wx:if="{{useMock}}">
        <text class="source-icon">⚠️</text>
        <text class="source-text">使用mock数据</text>
      </view>
    </view>

    <view class="model-list">
      <view 
        class="model-card" 
        wx:for="{{models}}" 
        wx:key="model_id"
        bindtap="selectModel"
        data-model="{{item}}"
      >
        <view class="model-image">
          <view class="image-placeholder">
            <text class="placeholder-icon">🔧</text>
          </view>
        </view>
        <view class="model-info">
          <text class="model-name">{{item.name}}</text>
          <text class="model-id mono">{{item.model_id}}</text>
          <view class="model-meta">
            <text class="meta-item">{{item.category}}</text>
            <view class="has-gltf" wx:if="{{hasGltf(item)}}">
              <text class="gltf-icon">3D</text>
            </view>
          </view>
        </view>
        <text class="model-arrow">→</text>
      </view>
    </view>

    <view class="empty-state" wx:if="{{models.length === 0 && !isLoading}}">
      <text class="empty-icon">📦</text>
      <text class="empty-title">暂无模型</text>
      <text class="empty-text">请检查后端服务是否正常运行</text>
    </view>

    <view class="loading-state" wx:if="{{isLoading}}">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>
  </view>
</view>