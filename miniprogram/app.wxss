page {
  background-color: #F8FAFC;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #0F172A;
  box-sizing: border-box;
}

view, text, image {
  box-sizing: border-box;
}

.page-container {
  min-height: 100vh;
  background-color: #F8FAFC;
}

button {
  margin: 0;
  padding: 0;
  background: none;
  border: none;
}

button::after {
  display: none;
}

scroll-view {
  -webkit-overflow-scrolling: touch;
}

::-webkit-scrollbar {
  width: 0;
  height: 0;
  background: transparent;
}